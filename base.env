# Plantilla de variables de entorno.
# Copia este fichero a .env en la raíz del proyecto y rellena los valores:
#   copy base.env .env      (Windows)
#   cp base.env .env        (Linux/Mac)
# El backend carga el .env de la raíz (no el de backend/).

# Puerto del backend. Opcional; por defecto 5000.
PORT=5000

# Clave de administrador para gestionar datos desde la web (crear/editar/borrar
# enlaces y servidores). Obligatoria para las operaciones de escritura:
# si está vacía o ausente, la API rechaza las escrituras con 503 (fail-closed).
# Usa una clave larga y privada que solo conozcas tú.
ADMIN_KEY=cambia-esta-clave-por-una-secreta
